{
  "name": "ham-net-checkin",
  "private": true,
  "version": "0.1.6",
  "productName": "HAM 台网点名主控台",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable --x64",
    "preview": "vite preview",
    "serve": "node server/index.mjs"
  },
  "build": {
    "appId": "net.bh1jss.ham-checkin",
    "productName": "HAM 台网点名主控台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "public/favicon.svg",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HAM 台网点名主控台"
    }
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "exceljs": "^4.4.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.12"
  }
}
