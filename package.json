{
  "name": "ham-net-checkin",
  "private": true,
  "version": "0.9.1",
  "productName": "HAM 台网点名主控台",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/copy-base-profiles.mjs",
    "profiles:build": "node scripts/build-base-profiles.mjs",
    "profiles:audit": "node scripts/audit-base-profiles.mjs",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win portable dir --x64",
    "preview": "vite preview",
    "serve": "node server/index.mjs",
    "dist:mac": "npm run build && electron-builder --mac dmg --x64",
    "dist:mac:universal": "npm run build && electron-builder --mac dmg --universal --publish never"
  },
  "build": {
    "appId": "net.bh1jss.ham-checkin",
    "productName": "HAM 台网点名主控台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "build/icon.icns",
      "build/icon.png",
      "electron/**/*",
      "server/**/*",
      "public/favicon.svg",
      "public/favicon.png",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "notarize": true,
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "HAM 台网点名主控台需要访问局域网内的 MMDVM、HAMBOX 和 FMO 设备，用于读取 Last Heard 与实时点名数据。",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    }
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "exceljs": "^4.4.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.12"
  }
}
